{
  "name": "clinica-mvp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "node scripts/lint.js",
    "type-check": "tsc --noEmit --pretty false",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "MIGRATE_TARGET=local drizzle-kit migrate",
    "db:migrate:prod": "MIGRATE_TARGET=prod drizzle-kit migrate",
    "db:migrate:all": "pnpm db:migrate && pnpm db:migrate:prod",
    "db:studio": "MIGRATE_TARGET=local drizzle-kit studio",
    "db:studio:prod": "MIGRATE_TARGET=prod drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:create-admin": "tsx scripts/create-admin.ts",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild"
    ],
    "overrides": {
      "esbuild": "^0.25.12",
      "fast-xml-parser": "^5.7.0",
      "fast-xml-builder": "^1.1.7",
      "fast-uri": "^3.1.2",
      "hono": "^4.12.18",
      "ip-address": "^10.1.1",
      "postcss": "^8.5.10"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@base-ui/react": "^1.4.0",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.6",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
