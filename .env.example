# Local Docker PostgreSQL (used by docker-compose.yml)
POSTGRES_USER=clinica
POSTGRES_PASSWORD=change-me
POSTGRES_DB=clinica_mvp

# Production database (Supabase)
# DATABASE_URL — Transaction pooler (port 6543): used by the app at runtime
DATABASE_URL=postgresql://clinica:change-me@db:5432/clinica_mvp
# MIGRATE_DATABASE_URL — Session pooler (port 5432, IPv4-only): used by drizzle-kit migrate
# Required when running migrations from WSL2 (direct db.*.supabase.co host is IPv6-only and unreachable).
# In Supabase dashboard: Connect → Session Pooler → copy the connection string (port 5432).
# MIGRATE_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Auth - JWT secrets (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-at-least-32-chars-long
JWT_REFRESH_SECRET=your-refresh-jwt-secret-at-least-32-chars-long

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=production
# APP_IMAGE=ghcr.io/your-org/clinica-mvp:latest

# Cloudflare R2 Storage
STORAGE_PROVIDER=r2
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=clinica-attachments
R2_REGION=auto

# Resend (email delivery for patient history PDFs)
# Server-only — do NOT expose with NEXT_PUBLIC_ prefix. When unset, the
# "Enviar historial por correo" feature is disabled with a clear error.
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=no-reply@yourclinic.example
RESEND_FROM_NAME=Hisamed
